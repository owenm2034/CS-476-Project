@model Room2Room.Models.DTOs.AdminUsersViewModel

<div class="my-4">
    @Html.AntiForgeryToken()

    <form class="row row-cols-lg-auto g-3 align-items-center" onsubmit="return false;">
        <div class="col-12">
            <label class="visually-hidden" for="adminUserSearchTerm">Search users</label>
            <div class="input-group">
                <input
                    type="text"
                    class="form-control"
                    value="@Model.STerm"
                    id="adminUserSearchTerm"
                    name="adminUserSearchTerm"
                    placeholder="Search by email, username, or university..."
                >
            </div>
        </div>

        <div class="col-12">
            <button type="button" class="btn btn-primary" onclick="searchAdminUsers()">Search</button>
            <a class="btn btn-primary" onclick="loadAdminUsers()">Reset</a>
        </div>
    </form>
</div>

@if (Model.Users != null && Model.Users.Any())
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>University</th>
                <th>Role</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>@user.Username</td>
                    <td>@user.Email</td>
                    <td>@user.UniversityName</td>
                    <td>
                        @if (user.IsAdmin)
                        {
                            <span class="badge bg-danger">Admin</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">User</span>
                        }
                    </td>
                    <td>
                        @if (user.AccountStatus == "Suspended")
                        {
                            <span class="badge bg-warning text-dark">Suspended</span>
                        }
                        else if (user.AccountStatus == "Deactivated")
                        {
                            <span class="badge bg-danger">Deactivated</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Active</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex gap-2 flex-wrap">
                            <a class="btn btn-outline-primary btn-sm"
                               asp-controller="Admin"
                               asp-action="EditUser"
                               asp-route-id="@user.Id">
                                Edit Account
                            </a>

                            @if (user.AccountStatus == "Active")
                            {
                                <button type="button"
                                        class="btn btn-outline-warning btn-sm"
                                        onclick="updateUserStatus(@user.Id, 'Suspended')">
                                    Suspend
                                </button>

                                <button type="button"
                                        class="btn btn-outline-danger btn-sm"
                                        onclick="updateUserStatus(@user.Id, 'Deactivated')">
                                    Deactivate
                                </button>
                            }
                            else
                            {
                                <button type="button"
                                        class="btn btn-outline-success btn-sm"
                                        onclick="updateUserStatus(@user.Id, 'Active')">
                                    Reactivate
                                </button>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No users found.</p>
}