@using Room2Room.Models.Chats
@model System.Collections.Generic.List<Room2Room.Models.Chats.ChatModel>

@for (int i = 0; i < Model.Count; i++)
{
    var cm = Model[i];
    <div id="chat-messages-@(cm.Chat.ChatId)" class="chat-message-container" style="visibility: hidden; display: none; flex-direction: column; overflow-y: auto; min-height: 400px; max-height: 530px">
        @Html.Partial("_Messages", cm)
    </div>
}