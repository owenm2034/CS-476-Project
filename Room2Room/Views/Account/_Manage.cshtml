@using Room2Room.Models.NotificationPreferences
@model Room2Room.Models.Accounts.ManageModel

@*
TODO:
*add error message upon invalid verification
    - email address domain not valid
    - new password parameters not met
    - any restrictions on profile pic image
* prefill existing information into textboxes
*@


<form id="manage-account-form" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        @Html.LabelFor(m => m.Email, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email" })
        @Html.ValidationMessageFor(m => m.Email, null, new { @class = "text-danger" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.Username, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.Username, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Username, null, new { @class = "text-danger" })
    </div>

    <br><h3>Change Password</h3>
    <div class="mb-3">
        @Html.LabelFor(m => m.OldPassword, "Current Password", new { @class = "form-label" })
        @Html.PasswordFor(m => m.OldPassword, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.OldPassword, null, new { @class = "text-danger" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.Password, "New Password", new { @class = "form-label" })
        @Html.PasswordFor(m => m.Password, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Password, null, new { @class = "text-danger" })
    </div>

     <div style="display: none" class="mb-3">
        @Html.CheckBoxFor(m => m.NotificationPreferences.RecieveEmailNotificationOnChatMessageRecieved)
        @Html.LabelFor(m => m.NotificationPreferences.RecieveEmailNotificationOnChatMessageRecieved, "Receive email notifications for new chat messages.", new { @class = "form-label" })
    </div>

    @if(User.IsInRole("Admin")) {
        <div class="mb-3">
            @Html.CheckBoxFor(m => (m.NotificationPreferences).RecieveEmailNotificationOnListingReported)
            @Html.LabelFor(m => (m.NotificationPreferences).RecieveEmailNotificationOnListingReported, "Receive email notifications when a listing is reported.", new { @class = "form-label" })
        </div>
        
        <div class="mb-3">
            @Html.CheckBoxFor(m => (m.NotificationPreferences).RecieveEmailNotificationOnUserReported)
            @Html.LabelFor(m => (m.NotificationPreferences).RecieveEmailNotificationOnUserReported, "Receive email notifications when a user is reported.", new { @class = "form-label" })
        </div>
    }
    <div class="mb-3">
        <label class="form-label">Profile Picture</label>
        <div class="mb-2">
            <img src="@(string.IsNullOrEmpty(Model.CurrentProfilePictureUrl) ? "/images/default_pfp.png" : Model.CurrentProfilePictureUrl)" 
                 class="rounded-circle" 
                 style="width: 80px; height: 80px; object-fit: cover;" />
        </div>
        <input type="file" name="NewProfilePicture" class="form-control" accept="image/*" />
        <div class="form-text">Optional: Select a new photo to change your profile picture.</div>   
    </div>

    <button type="button" class="btn btn-primary" onclick="saveChanges()">Save changes</button>

    <span class="text-danger">
        @(Model?.ErrorMessage ?? "")
    </span>

    <span class="text-success">
        @(Model?.SuccessMessage ?? "")
    </span>
</form>