@model Room2Room.Models.Accounts.RegisterModel

@using (Html.BeginForm("Register", "Account", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <div class="mb-3">
        @Html.LabelFor(m => m.Email, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email" })
        @Html.ValidationMessageFor(m => m.Email, null, new { @class = "text-danger" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.Username, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.Username, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Username, null, new { @class = "text-danger" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.Password, new { @class = "form-label" })
        @Html.PasswordFor(m => m.Password, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Password, null, new { @class = "text-danger" })
    </div>

    <div class="mb-3">
        <label for="ProfilePicture" class="form-label">Profile Picture</label>
        <input type="file" 
            name="ProfilePicture" 
            id="ProfilePicture" 
            class="form-control" 
            accept="image/*"
            onchange = "validateFileSize(this)" />
        <div class="form-text">Optional: Choose a square image for best results.</div>
        @Html.ValidationMessageFor(m => m.ProfilePicture, null, new { @class = "text-danger" })
    </div>

    <button type="submit" class="btn btn-primary">Register</button>

    <span class="text-danger">
        @(Model?.ErrorMessage ?? "")
    </span>

    <script>
        function validateFileSize(input) {
            var maxSize = 1024 * 1024; // 1mb
            if (input.files[0].size > maxSize) {
                alert("File must smaller than 1MB.");
                input.value = "";
            }
        }
    </script>
}